PORT=8000
NODE_ENV=production

# Required: pooled PostgreSQL connection string used by backend runtime and Prisma client.
# Example (Supabase pooler): postgresql://user:password@host:6543/postgres?pgbouncer=true
DATABASE_URL=

# Required for Prisma migrations (direct DB connection, not pooler).
# Example (Supabase direct): postgresql://user:password@host:5432/postgres
DIRECT_URL=

# Optional for future Redis integration.
# Current backend cache is in-memory and does not use Redis yet.
REDIS_URL=

# Required for Google OAuth login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required in production.
JWT_SECRET=

# Frontend origin for CORS, e.g. https://app.yourdomain.com
FRONTEND_URL=

# AI provider keys (set the ones you actually use)
DEFAULT_AI_PROVIDER=groq
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_AI_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Judge0 execution service
JUDGE0_URL=https://ce.judge0.com
JUDGE0_API_KEY=
