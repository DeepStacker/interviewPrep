# Public frontend env values used at build time
# Production backend API base (include /api suffix)
VITE_API_BASE_URL=https://interviewprep-backend.onrender.com/api

# Google OAuth client id used by frontend login
VITE_GOOGLE_CLIENT_ID=

# Dev-only local proxy target for Vite dev server
VITE_PROXY_TARGET=http://localhost:8000
